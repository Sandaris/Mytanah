# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Exa API key from https://dashboard.exa.ai — REQUIRED for property valuation
# (POST /valuation/predict searches Malaysian property portals for comparable
# sale prices) and used for live rent comps. Without it, valuation returns an
# "unavailable" result. For rent comps it takes priority over HERMES_URL and the
# local Playwright agent.
EXA_API_KEY=your-exa-api-key-here

# Optional Exa tuning for rent comps (defaults shown):
# EXA_EFFORT=medium
# EXA_TIMEOUT_MS=180000

# Optional Exa tuning for valuation (defaults shown):
# VAL_EXA_EFFORT=medium
# VAL_EXA_TIMEOUT_MS=180000

# Optional: hermes desktop agent URL (ngrok/Cloudflare tunnel exposing port 8001).
# Used only when EXA_API_KEY is not set.
# Example: HERMES_URL=https://xxxx-xx-xx-xx.ngrok-free.app
HERMES_URL=
